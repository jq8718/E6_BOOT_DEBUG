menu "USB to I2C Bridge Configuration"

    config I2C_SDA_GPIO
        int "I2C SDA GPIO number"
        default 7
        range 0 54
        help
            GPIO number for I2C SDA signal.
            ESP32-P4 default: GPIO7

    config I2C_SCL_GPIO
        int "I2C SCL GPIO number"
        default 8
        range 0 54
        help
            GPIO number for I2C SCL signal.
            ESP32-P4 default: GPIO8

    config I2C_MASTER_FREQ_HZ
        int "I2C master clock frequency (Hz)"
        default 100000
        range 10000 400000
        help
            I2C bus clock frequency in Hz.
            Standard mode: 100000 (100 kHz)
            Fast mode: 400000 (400 kHz)

endmenu
